{
  "darkmode": true,
  "themeLocation": "theme.json",
  "easycom": {
    "autoscan": true,
    "custom": {
      "^app-shell$": "@/components/AppShell.vue",
      "^app-option-button$": "@/components/AppOptionButton.vue",
      "^app-option-group$": "@/components/AppOptionGroup.vue",
      "^theme-swatch-picker$": "@/components/ThemeSwatchPicker.vue",
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/settings/settings",
      "style": {
        "navigationBarTitleText": "基础设置"
      }
    },
    {
      "path": "pages/design-preview/design-preview",
      "style": {
        "navigationBarTitleText": "能力预览"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "@navTxtStyle",
    "navigationBarTitleText": "小程序架构",
    "navigationBarBackgroundColor": "@navBgColor",
    "backgroundColor": "@pageBgColor",
    "backgroundColorTop": "@pageBgTopColor",
    "backgroundColorBottom": "@pageBgBottomColor",
    "backgroundTextStyle": "@pageBgTextStyle"
  }
}
