{
  "darkmode": true,
  "themeLocation": "theme.json",
  "easycom": {
    "autoscan": true,
    "custom": {
      "^app-shell$": "@/components/AppShell.vue",
      "^app-custom-nav$": "@/components/AppCustomNav.vue",
      "^app-option-button$": "@/components/AppOptionButton.vue",
      "^app-option-group$": "@/components/AppOptionGroup.vue",
      "^app-animated-swap$": "@/components/AppAnimatedSwap.vue",
      "^app-date-field$": "@/components/AppDateField.vue",
      "^empty-state$": "@/components/EmptyState.vue",
      "^entry-card$": "@/components/EntryCard.vue",
      "^image-grid$": "@/components/ImageGrid.vue",
      "^theme-swatch-picker$": "@/components/ThemeSwatchPicker.vue",
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "小珊的树洞",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/detail/detail",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "翻这张小纸页"
      }
    },
    {
      "path": "pages/create/create",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "写进小本本"
      }
    },
    {
      "path": "pages/songs/songs",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "小歌单"
      }
    },
    {
      "path": "pages/song-edit/song-edit",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "点歌便签"
      }
    },
    {
      "path": "pages/tasks/tasks",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "小约定"
      }
    },
    {
      "path": "pages/task-edit/task-edit",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "小约定票根"
      }
    },
    {
      "path": "pages/settings/settings",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "小纸样本"
      }
    },
    {
      "path": "pages/design-preview/design-preview",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "小样本预览"
      }
    },
    {
      "path": "pages/memos/memos",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "她的小档案"
      }
    },
    {
      "path": "pages/memo-edit/memo-edit",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "写小线索"
      }
    }
  ],
  "globalStyle": {
    "navigationStyle": "custom",
    "navigationBarTextStyle": "@navTxtStyle",
    "navigationBarTitleText": "小珊的树洞",
    "navigationBarBackgroundColor": "@navBgColor",
    "backgroundColor": "@pageBgColor",
    "backgroundColorTop": "@pageBgTopColor",
    "backgroundColorBottom": "@pageBgBottomColor",
    "backgroundTextStyle": "@pageBgTextStyle"
  }
}
