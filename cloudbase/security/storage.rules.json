{
  "version": "1.0",
  "rules": [
    {
      "path": "love-entries/main/**",
      "read": "auth.openid != null && auth.openid in ['__OWNER_OPENID__','__PARTNER_OPENID__']",
      "write": "auth.openid != null && auth.openid in ['__OWNER_OPENID__','__PARTNER_OPENID__']",
      "delete": "auth.openid != null && auth.openid in ['__OWNER_OPENID__','__PARTNER_OPENID__']"
    },
    {
      "path": "**",
      "read": false,
      "write": false,
      "delete": false
    }
  ]
}
